# Flask 运行环境
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# 数据库连接配置
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=classified_system

# 安全配置（必须使用随机值）
SECRET_KEY=
AES_KEY_B64=

# 会话配置
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_MINUTES=30

# Dlib 68 点关键点模型路径
DLIB_LANDMARK_MODEL_PATH=resource_models/shape_predictor_68_face_landmarks.dat

# 模块9：文件加解密配置
FILE_KEY_DIR=keys
FILE_CRYPTO_CHUNK_SIZE=1048576
